# Copia a .env (local) o configura estas variables en Vercel / Streamlit Cloud.

# ── API (FastAPI) ─────────────────────────────────────────────────────────────
# Connection string de Postgres (Supabase). Sin esto, la API usa SQLite efímero
# en /tmp que se BORRA en cada cold start — no sirve para un piloto real.
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres

# Clave para firmar los JWT. Genera una larga y aleatoria; nunca la reutilices.
SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria

# ── UI (Streamlit) ────────────────────────────────────────────────────────────
# URL pública de la API desplegada (sin barra final).
CENIT_API_URL=https://cenit-lilac.vercel.app
